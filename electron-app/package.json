{
  "name": "mytracker-electron",
  "version": "1.0.0",
  "description": "Privacy-first, local productivity tracker",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,ELECTRON -c cyan,yellow \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 5173",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build src/renderer"
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mytracker.app",
    "productName": "MyTracker",
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*"
    ],
    "directories": {
      "output": "dist/electron"
    }
  }
}
